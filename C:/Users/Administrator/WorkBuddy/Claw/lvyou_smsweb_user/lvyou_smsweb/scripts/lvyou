#!/usr/bin/env bash
set -euo pipefail

# lvyou - Board Manager 一站式管理命令

# 颜色定义
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
NC=$'\033[0m'

APPDIR="/opt/board-manager"
CONFIG_FILE="/etc/board-manager.conf"
CLI_FILE="/usr/local/bin/lvyou"
SERVICE_NAME_V4="board-manager-v4"
SERVICE_NAME_V6="board-manager-v6"

log_info() { printf '%b\n' "${GREEN}[✓]${NC} $*"; }
log_warn() { printf '%b\n' "${YELLOW}[!]${NC} $*"; }
log_err() { printf '%b\n' "${RED}[✗]${NC} $*"; }
log_title() { printf '\n%b━━━ %s ━━━%b\n\n' "${BOLD}${BLUE}" "$*" "${NC}"; }

need_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    log_err "请使用 sudo 运行此命令"
    exit 1
  fi
}

load_config() {
  if [[ -f "${CONFIG_FILE}" ]]; then
    # shellcheck disable=SC1090
    source "${CONFIG_FILE}"
  fi
}

show_banner() {
  printf '%b' "${CYAN}"
  printf '  %b██╗  ██╗ █████╗ ██████╗ ██████╗ ██╗    ██╗██╗   ██╗██╗  ██╗%b\n' "${BOLD}" "${NC}"
  printf '  %b██║ ██╔╝██╔══██╗██╔══██╗██╔══██╗██║    ██║██║   ██║╚██╗██╔╝%b\n' "${BOLD}" "${NC}"
  printf '  %b█████╔╝ ███████║██████╔╝██████╔╝██║ █╗ ██║██║   ██║ ╚███╔╝ %b\n' "${BOLD}" "${NC}"
  printf '  %b██╔═██╗ ██╔══██║██╔══██╗██╔══██╗██║██╗██║██║   ██║ ██╔██╗ %b\n' "${BOLD}" "${NC}"
  printf '  %b██║  ██╗██║  ██║██║  ██║██║  ██║╚███╔███╔╝╚██████╔╝██╔╝ ██╗%b\n' "${BOLD}" "${NC}"
  printf '  %b╚═╝  ╚═╝╚═╝  ╚═╝╚═╝  ╚═╝╚═╝  ╚═╝ ╚══╝╚══╝  ╚═════╝ ╚═╝  ╚═╝%b\n' "${BOLD}" "${NC}"
  printf '%b' "${NC}"
  printf '  %bBoard Manager 管理工具%b v1.0\n' "${BOLD}" "${NC}"
  printf '\n'
}

show_menu() {
  show_banner
  printf '%b请选择操作:%b\n\n' "${BOLD}" "${NC}"
  printf '  %b1%b. 查看日志 (logs)\n' "${GREEN}" "${NC}"
  printf '  %b2%b. 重启服务 (restart)\n' "${GREEN}" "${NC}"
  printf '  %b3%b. 查看服务状态 (status)\n' "${GREEN}" "${NC}"
  printf '  %b4%b. 查看配置文件 (config)\n' "${GREEN}" "${NC}"
  printf '  %b5%b. 更改 UI 密码\n' "${GREEN}" "${NC}"
  printf '  %b6%b. 更改服务端口\n' "${GREEN}" "${NC}"
  printf '  %b7%b. 卸载程序\n' "${GREEN}" "${NC}"
  printf '  %b8%b. 重装程序\n' "${GREEN}" "${NC}"
  printf '\n'
  printf '  %b9%b. 快速访问地址\n' "${GREEN}" "${NC}"
  printf '  %b0%b. 退出\n' "${GREEN}" "${NC}"
  printf '\n'
  printf '请输入选项 [0-9]: '
}

do_logs() {
  log_title "查看日志 (最近 100 行)"
  journalctl -u "${SERVICE_NAME_V4}" -u "${SERVICE_NAME_V6}" -n 100 --no-pager
}

do_restart() {
  log_title "重启服务"
  systemctl restart "${SERVICE_NAME_V4}" "${SERVICE_NAME_V6}"
  sleep 1
  do_status
}

do_status() {
  log_title "服务状态"
  printf '%bIPv4 服务:%b\n' "${BOLD}" "${NC}"
  if systemctl is-active --quiet "${SERVICE_NAME_V4}"; then
    log_info "${SERVICE_NAME_V4} 运行中"
  else
    log_err "${SERVICE_NAME_V4} 未运行"
  fi

  printf '\n%bIPv6 服务:%b\n' "${BOLD}" "${NC}"
  if systemctl is-active --quiet "${SERVICE_NAME_V6}"; then
    log_info "${SERVICE_NAME_V6} 运行中"
  else
    log_err "${SERVICE_NAME_V6} 未运行"
  fi

  load_config
  if [[ -n "${APIPORT:-}" ]]; then
    printf '\n%b配置信息:%b\n' "${BOLD}" "${NC}"
    printf '  端口: %s\n' "${APIPORT}"
    printf '  扫描账号: %s\n' "${SCANUSER:-admin}"
    printf '  程序目录: %s\n' "${APPDIR}"
    printf '  配置文件: %s\n' "${CONFIG_FILE}"
  fi
}

do_config() {
  log_title "配置文件内容"
  if [[ -f "${CONFIG_FILE}" ]]; then
    cat "${CONFIG_FILE}"
    printf '\n'
  else
    log_err "配置文件不存在: ${CONFIG_FILE}"
  fi
}

do_change_password() {
  log_title "更改 UI 密码"
  load_config

  printf '请输入新密码 (至少6位): '
  read -rs pass1
  printf '\n'

  if [[ ${#pass1} -lt 6 ]]; then
    log_err "密码至少需要 6 位"
    return 1
  fi

  printf '请再次输入密码: '
  read -rs pass2
  printf '\n'

  if [[ "${pass1}" != "${pass2}" ]]; then
    log_err "两次输入不一致"
    return 1
  fi

  # FIX(N8): rewrite the config file atomically via awk instead of sed so that
  # passwords containing shell/regex meta characters (/ & " \ $ ' newline) do
  # not corrupt the config or break the sed expression.
  local tmp_file
  tmp_file="$(mktemp)"
  if [[ -f "${CONFIG_FILE}" ]]; then
    awk -v new_pass="${pass1}" '
      BEGIN { written = 0 }
      /^UIPASS=/ { printf "UIPASS=\"%s\"\n", new_pass; written = 1; next }
      { print }
      END { if (!written) printf "UIPASS=\"%s\"\n", new_pass }
    ' "${CONFIG_FILE}" > "${tmp_file}"
  else
    printf 'UIPASS="%s"\n' "${pass1}" > "${tmp_file}"
  fi
  chmod --reference="${CONFIG_FILE}" "${tmp_file}" 2>/dev/null || chmod 600 "${tmp_file}"
  mv -f "${tmp_file}" "${CONFIG_FILE}"
  log_info "密码已更新"

  printf '是否重启服务使配置生效? (Y/n): '
  read -r confirm
  confirm="${confirm:-Y}"
  if [[ "${confirm}" =~ ^[Yy] ]]; then
    systemctl restart "${SERVICE_NAME_V4}" "${SERVICE_NAME_V6}"
    log_info "服务已重启"
  fi
}

do_change_port() {
  log_title "更改服务端口"
  load_config

  local current_port="${APIPORT:-8000}"
  printf '当前端口: %s\n' "${current_port}"
  printf '请输入新端口 [%s]: ' "${current_port}"
  read -r new_port
  new_port="${new_port:-${current_port}}"

  if [[ ! "${new_port}" =~ ^[0-9]+$ ]]; then
    log_err "端口必须为数字"
    return 1
  fi

  if (( new_port < 1 || new_port > 65535 )); then
    log_err "端口范围必须在 1-65535 之间"
    return 1
  fi

  if ss -ltn 2>/dev/null | grep -q ":${new_port} " && [[ "${new_port}" != "${current_port}" ]]; then
    log_err "端口 ${new_port} 已被占用"
    return 1
  fi

  # FIX(N9): back up the config + unit files before editing, and write the
  # port value via a temp-file swap so an interrupted edit cannot leave the
  # service with a truncated config.
  local ts
  ts="$(date +%s)"
  cp -a "${CONFIG_FILE}" "${CONFIG_FILE}.bak.${ts}"

  local tmp_cfg
  tmp_cfg="$(mktemp)"
  awk -v new_port="${new_port}" '
    BEGIN { written = 0 }
    /^APIPORT=/ { printf "APIPORT=\"%s\"\n", new_port; written = 1; next }
    { print }
    END { if (!written) printf "APIPORT=\"%s\"\n", new_port }
  ' "${CONFIG_FILE}" > "${tmp_cfg}"
  chmod --reference="${CONFIG_FILE}" "${tmp_cfg}" 2>/dev/null || chmod 600 "${tmp_cfg}"
  mv -f "${tmp_cfg}" "${CONFIG_FILE}"
  log_info "端口已更新为: ${new_port}"

  local unit
  for unit in "${SERVICE_NAME_V4}" "${SERVICE_NAME_V6}"; do
    local unit_path="/etc/systemd/system/${unit}.service"
    if [[ -f "${unit_path}" ]]; then
      cp -a "${unit_path}" "${unit_path}.bak.${ts}"
      sed -i "s/--port [0-9]\\{1,5\\}/--port ${new_port}/g" "${unit_path}"
    fi
  done

  systemctl daemon-reload

  printf '是否重启服务使配置生效? (Y/n): '
  read -r confirm
  confirm="${confirm:-Y}"
  if [[ "${confirm}" =~ ^[Yy] ]]; then
    systemctl restart "${SERVICE_NAME_V4}" "${SERVICE_NAME_V6}"
    log_info "服务已重启"
  fi
}

do_uninstall() {
  log_title "卸载程序"

  printf '\n'
  log_warn "警告：这将删除以下内容："
  printf '  - %s\n' "${APPDIR}"
  printf '  - %s\n' "${CONFIG_FILE}"
  printf '  - systemd 服务\n'
  printf '  - /usr/local/bin/lvyou 命令\n'
  printf '\n'

  printf '确认卸载? (y/N): '
  read -r confirm
  if [[ ! "${confirm}" =~ ^[Yy] ]]; then
    log_info "已取消"
    return 0
  fi

  systemctl stop "${SERVICE_NAME_V4}" 2>/dev/null || true
  systemctl stop "${SERVICE_NAME_V6}" 2>/dev/null || true
  systemctl disable "${SERVICE_NAME_V4}" 2>/dev/null || true
  systemctl disable "${SERVICE_NAME_V6}" 2>/dev/null || true

  rm -f /etc/systemd/system/"${SERVICE_NAME_V4}".service
  rm -f /etc/systemd/system/"${SERVICE_NAME_V6}".service
  systemctl daemon-reload

  [[ -d "${APPDIR}" ]] && rm -rf "${APPDIR}" && log_info "已删除 ${APPDIR}"
  [[ -f "${CONFIG_FILE}" ]] && rm -f "${CONFIG_FILE}" && log_info "已删除 ${CONFIG_FILE}"
  [[ -f "${CLI_FILE}" ]] && rm -f "${CLI_FILE}" && log_info "已删除 ${CLI_FILE}"

  log_title "卸载完成"
  log_info "感谢使用！如需重新安装，请下载安装包后运行 ./install.sh"
}

do_reinstall() {
  log_title "重装程序"

  printf '是否先卸载旧版本? (Y/n): '
  read -r confirm
  confirm="${confirm:-Y}"

  if [[ "${confirm}" =~ ^[Yy] ]]; then
    do_uninstall
  fi

  printf '\n'
  log_info "请下载最新安装包并运行: ./install.sh"
}

do_url() {
  log_title "快速访问地址"

  local ip
  ip=$(ip route get 1.1.1.1 2>/dev/null | awk '/src/ {for(i=1;i<=NF;i++) if ($i=="src") print $(i+1)}' | head -n1)
  load_config
  local port="${APIPORT:-8000}"

  printf '\n'
  if [[ -n "${ip}" ]]; then
    printf '  %b推荐访问:%b %bhttp://%s:%s/%b\n' "${BOLD}" "${NC}" "${GREEN}" "${ip}" "${port}" "${NC}"
    printf '  适用于本机和其他设备访问\n'
  fi
  printf '  %b本地访问:%b %bhttp://127.0.0.1:%s/%b\n' "${BOLD}" "${NC}" "${GREEN}" "${port}" "${NC}"
  printf '\n'

  local ipv4_list
  ipv4_list=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print "  - "$2" "$4}' || true)
  if [[ -n "${ipv4_list}" ]]; then
    printf '%b所有 IPv4 地址:%b\n' "${BOLD}" "${NC}"
    printf '%b\n' "${ipv4_list}"
  fi

  printf '\n'
}

main() {
  local choice

  if [[ $# -eq 0 ]]; then
    need_root

    while true; do
      show_menu
      read -r choice
      printf '\n'

      case "${choice}" in
        1) do_logs ;;
        2) do_restart ;;
        3) do_status ;;
        4) do_config ;;
        5) do_change_password ;;
        6) do_change_port ;;
        7) do_uninstall; exit 0 ;;
        8) do_reinstall; exit 0 ;;
        9) do_url ;;
        0) printf '再见!\n'; exit 0 ;;
        *)
          if [[ -n "${choice}" ]]; then
            log_err "无效选项: ${choice}"
          fi
          ;;
      esac

      if [[ "${choice}" =~ ^[0-9]$ ]]; then
        printf '\n按 Enter 继续...'
        read -r
      fi
    done
  else
    local cmd="$1"
    shift 2>/dev/null || true

    case "${cmd}" in
      logs|log)
        need_root
        do_logs
        ;;
      restart|reload)
        need_root
        do_restart
        ;;
      status|stat)
        need_root
        do_status
        ;;
      config|cfg)
        need_root
        do_config
        ;;
      pass|password|pwd)
        need_root
        do_change_password
        ;;
      port)
        need_root
        do_change_port
        ;;
      uninstall|remove|rm)
        need_root
        do_uninstall
        ;;
      reinstall|rebuild)
        need_root
        do_reinstall
        ;;
      url|地址|访问)
        need_root
        do_url
        ;;
      -h|--help|help)
        printf 'lvyou - Board Manager 管理工具\n'
        printf '\n用法:\n'
        printf '  lvyou              # 交互式菜单\n'
        printf '  lvyou logs         # 查看日志\n'
        printf '  lvyou restart      # 重启服务\n'
        printf '  lvyou status       # 查看状态\n'
        printf '  lvyou config       # 查看配置\n'
        printf '  lvyou pass         # 更改密码\n'
        printf '  lvyou port         # 更改端口\n'
        printf '  lvyou url          # 访问地址\n'
        printf '  lvyou uninstall    # 卸载\n'
        ;;
      *)
        log_err "未知命令: ${cmd}"
        printf '使用 lvyou --help 查看帮助\n'
        exit 1
        ;;
    esac
  fi
}

main "$@"